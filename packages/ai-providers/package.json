{
  "name": "@a11y-ai/ai-providers",
  "version": "0.1.0",
  "description": "AI provider adapters for a11y-ai (OpenAI/Anthropic/Ollama/Mock).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vudayagirivaibhav/a11y-ai"
  },
  "homepage": "https://github.com/vudayagirivaibhav/a11y-ai",
  "bugs": {
    "url": "https://github.com/vudayagirivaibhav/a11y-ai/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "ai",
    "openai",
    "anthropic",
    "ollama",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@a11y-ai/core": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}
