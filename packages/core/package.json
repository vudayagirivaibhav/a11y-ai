{
  "name": "@a11y-ai/core",
  "version": "0.1.0",
  "description": "AI-powered accessibility auditor built on axe-core + AI analysis.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types-entry.d.ts",
      "import": "./dist/types-entry.mjs",
      "require": "./dist/types-entry.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vudayagirivaibhav/a11y-ai"
  },
  "homepage": "https://github.com/vudayagirivaibhav/a11y-ai",
  "bugs": {
    "url": "https://github.com/vudayagirivaibhav/a11y-ai/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "axe-core",
    "ai",
    "audit",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@a11y-ai/ai-providers": "workspace:*",
    "@a11y-ai/rules": "workspace:*",
    "axe-core": "^4.10.0"
  },
  "peerDependencies": {
    "jsdom": "^24.0.0",
    "playwright": "^1.41.0",
    "puppeteer": "^22.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "jsdom": "^24.0.0"
  }
}
