{
  "name": "@a11y-ai/rules",
  "version": "0.1.0",
  "description": "AI-powered accessibility rules engine for a11y-ai.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types-entry.d.ts",
      "import": "./dist/types-entry.mjs",
      "require": "./dist/types-entry.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vudayagirivaibhav/a11y-ai"
  },
  "homepage": "https://github.com/vudayagirivaibhav/a11y-ai",
  "bugs": {
    "url": "https://github.com/vudayagirivaibhav/a11y-ai/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "ai",
    "rules",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@a11y-ai/core": "workspace:*",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.5"
  }
}
